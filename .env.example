APP_NAME=Progest
APP_ENV=local
# ATENÇÃO PARA O APP_DOMAIN:
# No XAMPP / Docker Local: app.localhost
# Via Docker Produção: sistema-hospital.com.br
APP_DOMAIN=app.localhost
APP_KEY=
APP_DEBUG=true
APP_URL=https://${APP_DOMAIN}
FRONTEND_URL=https://${APP_DOMAIN}

LOG_CHANNEL=stack
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug

# Banco de Dados - Configuração Local (XAMPP)
DB_CONNECTION=mysql
DB_HOST=127.0.0.1
DB_PORT=3306
DB_DATABASE=progest
DB_USERNAME=root
DB_PASSWORD=

BROADCAST_DRIVER=log
CACHE_DRIVER=file
FILESYSTEM_DRIVER=local
QUEUE_CONNECTION=sync
SESSION_DRIVER=file
SESSION_LIFETIME=120